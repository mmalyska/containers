{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>mmalyska/renovate-config',
    'github>mmalyska/renovate-config:automerge-github-actions',
    'github>mmalyska/renovate-config:automerge-docker-digest',
  ],
  gitAuthor: 'bendo-bot <126472327+bendo-bot[bot]@users.noreply.github.com>',
  customManagers: [
    {
      customType: 'regex',
      description: 'Update azerothcore module commit SHAs',
      managerFilePatterns: [
        '/apps/azerothcore-worldserver/Dockerfile/',
      ],
      matchStrings: [
        '# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)\\nARG [A-Z_]+=(?<currentDigest>[0-9a-f]{40})',
      ],
      currentValueTemplate: 'master',
      versioningTemplate: 'loose',
    },
  ],
  packageRules: [
    {
      matchDatasources: [
        'docker',
      ],
      matchUpdateTypes: [
        'digest',
      ],
      commitMessagePrefix: '📣 ',
      automergeType: 'pr',
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchUpdateTypes: [
        'digest',
      ],
      groupName: 'azerothcore wow images',
      matchPackageNames: [
        '/^acore/ac-wotlk-/',
      ],
    },
    {
      matchDatasources: [
        'git-refs',
      ],
      groupName: 'azerothcore wow images',
      matchPackageNames: [
        '/azerothcore/mod-/',
      ],
    },
  ],
}
