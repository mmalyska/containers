{
  "name": "Container",
  "build": {
      "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/go:1": {}
  },
  "remoteUser": "vscode",
  "containerUser": "vscode",
  "postCreateCommand": "mkdir -p /home/vscode/.claude/projects/-workspaces-containers && ln -sfn /workspaces/containers/.claude /home/vscode/.claude/projects/-workspaces-containers/memory"
}
